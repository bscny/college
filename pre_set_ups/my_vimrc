set encoding=utf-8
map <C-m> :call SwitchMouseMode()<CR>
function SwitchMouseMode()
        if (&mouse == "a")
                let &mouse = ""
                echo "Mouse is disabled."
        else
                let &mouse = "a"
                echo "Mouse is enabled."
        endif
endfunction
highlight Comment    ctermfg=DarkCyan
highlight SpecialKey ctermfg=Yellow

"the autofill with tap
function InsertTabWrapper()
    let col = col('.') - 1
    if !col || getline('.')[col - 1] !~ '\k'
        return "\<tab>"
    else
        return "\<c-p>"
    endif
endfunction
inoremap <TAB> <C-R>=InsertTabWrapper()<CR>
set dictionary="/usr/dict/words"
set completeopt=menuone

set cscopetag
set csto=0

"automatically add cscope env file
if filereadable("cscope.out")
   cs add cscope.out
elseif $CSCOPE_DB != ""
    cs add $CSCOPE_DB
endif
set cscopeverbose

"hit <crtl> + <\> + <...> to use cscope
nmap <C-\>s :cs find s <C-R>=expand("<cword>")<CR><CR>
nmap <C-\>a :cs find a <C-R>=expand("<cword>")<CR><CR>
nmap <C-\>g :cs find g <C-R>=expand("<cword>")<CR><CR>
nmap <C-\>c :cs find c <C-R>=expand("<cword>")<CR><CR>
nmap <C-\>t :cs find t <C-R>=expand("<cword>")<CR><CR>
nmap <C-\>e :cs find e <C-R>=expand("<cword>")<CR><CR>
nmap <C-\>f :cs find f <C-R>=expand("<cfile>")<CR><CR>
